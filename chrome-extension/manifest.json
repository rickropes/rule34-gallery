{
  "manifest_version": 3,
  "name": "Gallery Post Importer",
  "version": "0.8.0",
  "description": "Send Rule34, Danbooru, Gelbooru, X/Twitter, and browser-managed image collections to the local gallery app.",
  "permissions": [
    "contextMenus",
    "notifications",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:37891/*",
    "https://rule34.xxx/*",
    "https://www.rule34.xxx/*",
    "https://danbooru.donmai.us/*",
    "https://www.danbooru.donmai.us/*",
    "https://gelbooru.com/*",
    "https://www.gelbooru.com/*",
    "https://x.com/*",
    "https://www.x.com/*",
    "https://twitter.com/*",
    "https://www.twitter.com/*",
    "https://nhentai.net/*",
    "https://*.nhentai.net/*",
    "https://*.nhentai.to/*",
    "https://e-hentai.org/*",
    "https://*.e-hentai.org/*",
    "https://exhentai.org/*",
    "https://*.exhentai.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://www.x.com/*",
        "https://twitter.com/*",
        "https://www.twitter.com/*"
      ],
      "js": [
        "page-hook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://x.com/*",
        "https://www.x.com/*",
        "https://twitter.com/*",
        "https://www.twitter.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://nhentai.net/*",
        "https://*.nhentai.net/*",
        "https://e-hentai.org/*",
        "https://*.e-hentai.org/*",
        "https://exhentai.org/*",
        "https://*.exhentai.org/*"
      ],
      "js": [
        "nhentai-pool.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
